# JARVIS Environment Variables
# Copy this to .env for local development (never commit .env)
# On Node.js Hosting (GoDaddy): set these via the platform UI

# PORT is provided automatically — do not set manually on GoDaddy Node.js Hosting
# PORT=3000

# Cloud Ollama endpoint (HTTPS only — port 443/80 required for GoDaddy hosting)
# Examples:
#   OLLAMA_URL=https://your-ollama.yourdomain.com
#   OLLAMA_URL=https://api.endpoints.anyscale.com   (Ollama-compatible)
# Leave blank to use only Claude API backend.
OLLAMA_URL=

# Claude API Key (optional — users can also set this in the app's ⚙ CONFIG panel)
# If set here, it's used server-side and never exposed to the browser.
# ANTHROPIC_KEY=sk-ant-...
